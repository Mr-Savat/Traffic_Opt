  <flow id="car_W" type="car" from="edge_W" to="edge_E_out" begin="0" end="3600" vehsPerHour="120" departLane="random"/>

  <!-- Tuk-tuks -->
  <flow id="tuk_N" type="tuktuk" from="edge_N" to="edge_S_out" begin="0" end="3600" vehsPerHour="60" departLane="random"/>
  <flow id="tuk_S" type="tuktuk" from="edge_S" to="edge_N_out" begin="0" end="3600" vehsPerHour="60" departLane="random"/>
  <flow id="tuk_E" type="tuktuk" from="edge_E" to="edge_W_out" begin="0" end="3600" vehsPerHour="50" departLane="random"/>
  <flow id="tuk_W" type="tuktuk" from="edge_W" to="edge_E_out" begin="0" end="3600" vehsPerHour="50" departLane="random"/>
</routes>
